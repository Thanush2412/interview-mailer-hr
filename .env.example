# Copy this to .env.local and fill in the values

# Google OAuth (GSI popup — no redirect URI needed)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Session secret — use a long random string (min 32 chars)
SESSION_SECRET=

# PostgreSQL (Xata)
DATABASE_URL=

# Google Apps Script Web App URL
GAS_URL=

# Google Sheet URL (pre-fills the sheet input on load)
NEXT_PUBLIC_SHEET_URL=
